# Since the ".env" file is gitignored, you can use the ".env.example" file to
# build a new ".env" file when you clone the repo. Keep this file up-to-date
# when you add new variables to `.env`.

# This file will be committed to version control, so make sure not to have any
# secrets in it. If you are cloning this repo, create a copy of this file named
# ".env" and populate it with your secrets.

# When adding additional environment variables, the schema in "src/env.ts"
# should be updated accordingly.

# =============================================================================
# REQUIRED (for app runtime)
# =============================================================================

# Supabase (get from https://supabase.com/)
NEXT_PUBLIC_SUPABASE_URL="your_supabase_project_url"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your_supabase_anon_key"
# Service role key - server-side only, never expose to client
SUPABASE_SERVICE_ROLE_KEY="your_supabase_service_role_key"

# Optional: secret for hashing share link passwords (defaults to a fallback if unset)
# SHARE_LINK_SECRET="your_random_secret"

# Google AI API (get from https://aistudio.google.com/apikey)
# Used for lease analysis with Gemini 2.0 Flash
GOOGLE_AI_API_KEY="your_google_ai_api_key"

# =============================================================================
# OPTIONAL - Database (Drizzle migrations)
# =============================================================================
# Used by pnpm db:migrate:manual and prebuild. If unset or unreachable, build
# skips migrations and continues. Set for local dev or when using Drizzle.
# DATABASE_URL="postgresql://postgres:password@localhost:5432/pdr_ai_v2"

# =============================================================================
# OPTIONAL - Legacy/Alternative AI
# =============================================================================

# OpenAI API (get from https://platform.openai.com/)
# Not currently used - Google AI is primary
OPENAI_API_KEY="your_openai_api_key"

# =============================================================================
# OPTIONAL - File Upload
# =============================================================================

# UploadThing (get from https://uploadthing.com/)
UPLOADTHING_SECRET="your_uploadthing_secret"
UPLOADTHING_APP_ID="your_uploadthing_app_id"

# Datalab OCR API (optional - get from https://www.datalab.to/)
# Required only if you want to enable OCR processing for scanned documents
DATALAB_API_KEY="your_datalab_api_key"

# =============================================================================
# OPTIONAL - Caching (Upstash Redis)
# =============================================================================

# Upstash Redis (get from https://upstash.com/)
# If not provided, falls back to in-memory caching
UPSTASH_REDIS_REST_URL="your_upstash_redis_url"
UPSTASH_REDIS_REST_TOKEN="your_upstash_redis_token"

# =============================================================================
# OPTIONAL - Monitoring & Analytics
# =============================================================================

# Sentry (get from https://sentry.io/)
# For error tracking and performance monitoring
SENTRY_DSN="your_sentry_dsn"

# PostHog (get from https://posthog.com/)
# For product analytics
NEXT_PUBLIC_POSTHOG_KEY="your_posthog_api_key"
NEXT_PUBLIC_POSTHOG_HOST="https://app.posthog.com"

# =============================================================================
# OPTIONAL - Payments (Stripe)
# =============================================================================

# Stripe (get from https://stripe.com/)
# For subscription billing - see docs/STRIPE_SETUP.md
STRIPE_SECRET_KEY="your_stripe_secret_key"
STRIPE_PUBLISHABLE_KEY="your_stripe_publishable_key"
STRIPE_WEBHOOK_SECRET="your_stripe_webhook_secret"

# Stripe Price IDs (create Products + Prices in Dashboard, then copy here)
STRIPE_SINGLE_PRICE_ID="price_xxx"   # Single plan $149/mo
STRIPE_TEAM_PRICE_ID="price_xxx"    # Team plan $399/mo
STRIPE_BROKER_PRICE_ID="price_xxx"  # Broker plan $799/mo

# App URL for Stripe redirects (checkout success/cancel)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# =============================================================================
# Environment
# =============================================================================

NODE_ENV="development"
